# ──────────────────────────────────────────────────────────────────────────────
# MusicSage — variáveis de ambiente
#
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── Plex ──────────────────────────────────────────────────────────────────────
# URL do servidor Plex Media Server
# Dentro de um container Docker na mesma host, use o IP do gateway (172.17.0.1)
# ou o nome do container se estiverem na mesma rede Docker.
PLEX_URL=http://localhost:32400

# Token de autenticação do Plex
# Obtenha em: https://www.plex.tv/claim/ ou via Settings > Account > XML (X-Plex-Token)
PLEX_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Ollama (LLM local) ────────────────────────────────────────────────────────
# URL do servidor Ollama — onde os modelos LLM estão rodando
OLLAMA_URL=http://localhost:11434

# Modelo padrão usado para recomendações e análises
# Opções testadas: deepseek-r1:1.5b | gemma4:e4b | llama3.2:3b
OLLAMA_DEFAULT_MODEL=gemma4:e4b

# Modelo de embeddings para clustering e playlist semântica
# Deve estar instalado no Ollama: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# ── Servidor ──────────────────────────────────────────────────────────────────
# Porta em que o servidor HTTP irá escutar
MUSICSAGE_PORT=3002

# ── Mídia local (para análise de áudio via ffmpeg/essentia) ──────────────────
# Caminho no host onde os arquivos de música estão armazenados
# (O Plex retorna caminhos como /music/Artista/Album/track.flac)
PLEX_MEDIA_ROOT=/home/developer/workspace/plex_server/music

# Prefixo do caminho que o Plex usa internamente (mapeado para PLEX_MEDIA_ROOT)
PLEX_PATH_PREFIX=/music

# ── Last.fm (opcional) ────────────────────────────────────────────────────────
# Habilita busca de artistas semelhantes via Last.fm
# Obtenha em: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ── Debug ─────────────────────────────────────────────────────────────────────
# Ativa logs verbosos (DEBUG) no console e no arquivo de log
# MUSICSAGE_DEBUG=1

# ── Node.js ───────────────────────────────────────────────────────────────────
# Não altere — usado internamente
# NODE_ENV=production
